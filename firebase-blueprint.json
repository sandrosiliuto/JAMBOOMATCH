{
  "entities": {
    "User": {
      "title": "User",
      "description": "A guest at the JAMBOO party.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Display name or nickname" },
        "photoUrl": { "type": "string", "description": "URL of the uploaded photo" },
        "instagram": { "type": "string", "description": "Instagram handle (without @)" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user registered" }
      },
      "required": ["uid", "name", "photoUrl", "instagram", "createdAt"]
    },
    "Like": {
      "title": "Like",
      "description": "A 'like' or 'fire' action from one user to another.",
      "type": "object",
      "properties": {
        "fromUid": { "type": "string", "description": "UID of the user who liked" },
        "toUid": { "type": "string", "description": "UID of the user being liked" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the like occurred" }
      },
      "required": ["fromUid", "toUid", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/likes/{likeId}": {
      "schema": "Like",
      "description": "Like records. likeId can be fromUid_toUid"
    }
  }
}
