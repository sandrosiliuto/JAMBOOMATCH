{
  "entities": {
    "Asistente": {
      "title": "Asistente",
      "description": "Un asistente a la fiesta JAMBOO.",
      "type": "object",
      "properties": {
        "nombre": { "type": "string", "description": "Nombre o apodo" },
        "instagram": { "type": "string", "description": "Usuario de Instagram (sin @)" },
        "fotoURL": { "type": "string", "description": "URL de la foto (base64 o link)" },
        "likesDados": { "type": "array", "items": { "type": "string" }, "description": "Lista de IDs de personas a las que les dio like" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Fecha de registro" }
      },
      "required": ["nombre", "instagram", "fotoURL", "likesDados", "createdAt"]
    }
  },
  "firestore": {
    "/asistentes/{asistenteId}": {
      "schema": "Asistente",
      "description": "Documentos de los asistentes"
    }
  }
}
