# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# MONGODB_URI: Connection string for Firestore MongoDB API
MONGODB_URI="mongodb://<username>:<password>@a0768593-8ab9-435b-82f9-2d77263e7e38.nam5.firestore.goog:443/jamboo?loadBalanced=true&tls=true&authMechanism=SCRAM-SHA-256&retryWrites=false"
